{
  "project_name": "DigitOCR_Project",
  "python": {
    "min_version": "3.10",
    "venv_dir": ".venv",
    "bootstrap_packages": [
      "pip",
      "setuptools",
      "wheel"
    ]
  },
  "manifests": [
    {
      "name": "python-runtime",
      "path": "requirements.txt",
      "manager": "pip",
      "type": "requirements",
      "optional": false,
      "cache_subdir": "pip"
    },
    {
      "name": "node-runtime",
      "path": "package.json",
      "manager": "npm",
      "type": "package-json",
      "optional": true,
      "include_dev_dependencies": false,
      "cache_subdir": "npm"
    }
  ],
  "system_dependencies": [
    {
      "name": "node-runtime",
      "optional": true,
      "platforms": [
        "windows",
        "macos",
        "linux"
      ],
      "manifest_managers": [
        "npm"
      ],
      "check_commands": [
        "node --version",
        "npm --version"
      ],
      "package_names": {
        "winget": "OpenJS.NodeJS.LTS",
        "brew": "node",
        "apt": "nodejs npm",
        "dnf": "nodejs npm",
        "yum": "nodejs npm",
        "pacman": "nodejs npm"
      }
    }
  ]
}
